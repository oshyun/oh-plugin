#!/usr/bin/env bash
# SessionStart hook — injects coding-style and workflow-style rules into every session

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

coding_style=$(cat "${PLUGIN_ROOT}/skills/coding-style/SKILL.md" 2>/dev/null || echo "")
workflow_style=$(cat "${PLUGIN_ROOT}/skills/workflow-style/SKILL.md" 2>/dev/null || echo "")

escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

coding_escaped=$(escape_for_json "$coding_style")
workflow_escaped=$(escape_for_json "$workflow_style")

context="<IMPORTANT>\n[oh-dev-guide rules — always applied]\n\n${coding_escaped}\n\n---\n\n${workflow_escaped}\n</IMPORTANT>"

if [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
    printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$context"
else
    printf '{\n  "additionalContext": "%s"\n}\n' "$context"
fi

exit 0
