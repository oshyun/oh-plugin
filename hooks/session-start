#!/usr/bin/env bash
# SessionStart hook — oh-coding-style / oh-workflow-style 스킬을 즉시 호출하도록 지시한다.

set -euo pipefail

context='[oh-plugin] 이 세션에 oh-plugin이 활성화되어 있습니다. oh-plugin:oh-coding-style 스킬은 코드 작업(작성·수정·리뷰·리팩토링)에 적용되는 명명 규칙·변경 범위·SSOT 규칙을 담고 있습니다. oh-plugin:oh-workflow-style 스킬은 git 작업(worktree·커밋·머지·push)에 적용되는 워크플로우 규칙을 담고 있습니다. 코드 또는 git 작업 시작 전에 해당 스킬을 로드해야 합니다.'

if [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
    printf '{"hookSpecificOutput":{"hookEventName":"SessionStart","additionalContext":"%s"}}\n' "$context"
else
    printf '{"additionalContext":"%s"}\n' "$context"
fi

exit 0
